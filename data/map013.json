{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":0,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Door2","direction":8,"pattern":0,"characterIndex":1},"list":[{"code":101,"indent":0,"parameters":["shane",0,2,2,"???"]},{"code":401,"indent":0,"parameters":["So, it appears you have found me"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"???"]},{"code":401,"indent":0,"parameters":["Its me, Shane, the guy who made this damn thing"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["You know i didnt want to self insert myself in"]},{"code":401,"indent":0,"parameters":["to the main game. but i feel like here is a"]},{"code":401,"indent":0,"parameters":["pretty good place instead"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["With that being said however. the reception"]},{"code":401,"indent":0,"parameters":["to this game was more than i could ever dream"]},{"code":401,"indent":0,"parameters":["of"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Dreams are a funny thing. arent they."]},{"code":401,"indent":0,"parameters":["sometimes they become reality, sometimes not"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["But the reality of this game, that i didnt"]},{"code":401,"indent":0,"parameters":["think would touch the hearts of so many people."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Well lets just say im glad that dream was wrong"]},{"code":401,"indent":0,"parameters":["and im so glad it had the effect that it did"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["And its times like that where its okay if"]},{"code":401,"indent":0,"parameters":["things dont plan out the way that you intend"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Like i said, i didnt intend for this game to"]},{"code":401,"indent":0,"parameters":["be so loved. and thats ok. because when i did"]},{"code":401,"indent":0,"parameters":["get proved wrong by all of you lovely people. "]},{"code":401,"indent":0,"parameters":["it caused me to genuinely have a loss for words"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Now i am more composed. i just want to say"]},{"code":401,"indent":0,"parameters":["thank you, if you are reading this."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["You matter a ton in this world, and if times"]},{"code":401,"indent":0,"parameters":["are tough for you right now. just know that"]},{"code":401,"indent":0,"parameters":["eventually.. things will get better."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Its always best to keep going and see the light"]},{"code":401,"indent":0,"parameters":["of day, even when things look bleak"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["And if you're having a good day, then im glad"]},{"code":401,"indent":0,"parameters":["that things are going well for you."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["I cant express how i felt in the moment. but i "]},{"code":401,"indent":0,"parameters":["do truely appreciate everyone that enjoyed this"]},{"code":401,"indent":0,"parameters":["little game. i appreciate it more than i could"]},{"code":401,"indent":0,"parameters":["ever convey"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["And im glad to have had an impact on not just"]},{"code":401,"indent":0,"parameters":["liv, but all of you"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Its so wierd how works of art like this can"]},{"code":401,"indent":0,"parameters":["tug on emotions so hard. but and i loved"]},{"code":401,"indent":0,"parameters":["creating these powerful, meaningful moments in"]},{"code":401,"indent":0,"parameters":["the game"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["So much so that i may never be able to do this"]},{"code":401,"indent":0,"parameters":["again..."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["And that makes me sad. "]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["I feel as if this is my magnum opus. of sorts."]},{"code":401,"indent":0,"parameters":["with the game and video together. i dont think"]},{"code":401,"indent":0,"parameters":["i can ever pull off something of this cailber"]},{"code":401,"indent":0,"parameters":["ever again"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["while this is true. i cant help but not look at"]},{"code":401,"indent":0,"parameters":["it positively it was nice to be surrounded by"]},{"code":401,"indent":0,"parameters":["so many individuals. Just look at what happens"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["We create something beautiful.."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["We create something memorable"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["And most importantly."]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["We create something that will live on forever"]},{"code":401,"indent":0,"parameters":["as a reminder to not just liv. but all of you"]},{"code":401,"indent":0,"parameters":["who have ever crossed paths with her"]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Thank you for listening to my thoughts and"]},{"code":401,"indent":0,"parameters":["feelings. "]},{"code":101,"indent":0,"parameters":["shane",0,2,2,"Shane"]},{"code":401,"indent":0,"parameters":["Until next time..."]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":5,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":6,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":11,"y":8},
