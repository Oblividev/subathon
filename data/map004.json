{"id":7,"name":"Angle","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":0,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"Angle","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":111,"indent":0,"parameters":[2,"A",1]},{"code":122,"indent":1,"parameters":[1,1,1,0,1]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":123,"indent":0,"parameters":["A",0]},{"code":101,"indent":0,"parameters":["Angle",0,0,2,"Angle"]},{"code":401,"indent":0,"parameters":["Ay up, Liv."]},{"code":213,"indent":0,"parameters":[0,2,false]},{"code":101,"indent":0,"parameters":["Angle",0,0,2,"Angle"]},{"code":401,"indent":0,"parameters":["How's it going, mush?"]},{"code":101,"indent":0,"parameters":["LivFaceV2",0,0,2,"Liv"]},{"code":401,"indent":0,"parameters":["Hey, Angle, boy, what did they do to you?"]},{"code":213,"indent":0,"parameters":[0,5,false]},{"code":101,"indent":0,"parameters":["Angle",0,0,2,"Angle"]},{"code":401,"indent":0,"parameters":["I know, right? Shane did me dirty, the rat."]},{"code":101,"indent":0,"parameters":["Angle",0,0,2,"Angle"]},{"code":401,"indent":0,"parameters":["Apparently there aren't enough hairstyles"]},{"code":401,"indent":0,"parameters":["that suit me, so this was the best they could"]},{"code":401,"indent":0,"parameters":["come up with."]},{"code":213,"indent":0,"parameters":[-1,2,false]},{"code":101,"indent":0,"parameters":["LivFaceV2",0,0,2,"Liv"]},{"code":401,"indent":0,"parameters":["Okay, but why are you in the kitchen?"]},{"code":101,"indent":0,"parameters":["Angle",0,0,2,"Angle"]},{"code":401,"indent":0,"parameters":["Well, Liv, I'm glad you asked, I've been"]},{"code":401,"indent":0,"parameters":["cooking up a storm."]},{"code":213,"indent":0,"parameters":[0,3,false]},{"code":101,"inde